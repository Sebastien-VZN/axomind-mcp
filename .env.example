# Axomind MCP credentials
# Copy this file to .env and fill in your values
# NEVER commit the .env file

# ── Bot API (bot_api.php) ──
# URL to the bot_api.php endpoint on the Axomind server
AXOMIND_BASE_URL=http://your-server/app/bot_api.php
# Bot ID (from Axomind UI → bot management)
AXOMIND_BOT_ID=your_bot_id
# Bot access key (generated when creating the bot in the UI)
AXOMIND_BOT_KEY=your_key_access

# ── User API (index.php — Atlas messaging) ──
# Shared key (KEY_PASS) required for all user API calls
AXOMIND_KEY_PASS=your_keypass
# Atlas user email
AXOMIND_USER_EMAIL=your_bot_email
# Atlas user password
AXOMIND_USER_PASSWORD=your_bot_password
# Type client identifier (determines which token column is used server-side)
AXOMIND_USER_TYPE_CLIENT=axomind_desktop
# Route prefix used by all user API routes (server-side shared secret)
# Found in app/core/_main/config_server.php → SUFIX_ROUTE constant
AXOMIND_ROUTE_PREFIX=<your_route_prefix>

# ── Daemon mode (autonomous, without Hermes) ──
# Ollama API endpoint for local model tool-calling (must end with /v1/chat/completions)
AXOMIND_OLLAMA_URL=http://your-ollama-host:11434/v1/chat/completions
# Ollama model tag (exact tag from `ollama list` — include quantization suffix)
AXOMIND_OLLAMA_MODEL=your_model_tag
# Ollama request timeout in seconds (120 recommended for cold-start of larger models)
AXOMIND_OLLAMA_TIMEOUT=120
# WebSocket URL for real-time events (ws://host:port/)
AXOMIND_WS_URL=ws://your-server:8080/

# ── Optional ──
# HTTP timeout in seconds for bot_api/user_api calls (default: 30)
AXOMIND_TIMEOUT=30
# Override the user API base URL (defaults to BASE_URL with bot_api.php replaced by index.php)
# AXOMIND_USER_BASE_URL=http://your-server/app/index.php